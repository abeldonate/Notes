\frametitle{Esquema de $R = \mathbb {Z}$}
\[
X = \Spec(\mathbb{Z}) = \{(0),(2), (3), (5), \ldots\}
\]

\[
    \begin{cases}
&\mathcal{F}(X_6)  = \left\{ \frac{a}{2^n3^n} : n \ge 0 \right\}\\
&\mathcal{F}(X_{10})  = \left\{ \frac{a}{2^n5^n} : n \ge 0 \right\}
    \end{cases}   \implies
    \mathcal{F}(X_6 \cup X_{10}) = \mathcal{F}(X_2)  = \left\{ \frac{a}{2^n} : n \ge 0\right\}
\]
\incfig{schemesZ}
